{
  "name": "immutable-chess",
  "version": "0.1.0-alpha.0",
  "description": "A TypeScript library for chess position representation and manipulation.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./moves": {
      "import": {
        "types": "./dist/moves.d.ts",
        "default": "./dist/moves.js"
      },
      "require": {
        "types": "./dist/moves.d.cts",
        "default": "./dist/moves.cjs"
      }
    },
    "./rules": {
      "import": {
        "types": "./dist/rules.d.ts",
        "default": "./dist/rules.js"
      },
      "require": {
        "types": "./dist/rules.d.cts",
        "default": "./dist/rules.cjs"
      }
    },
    "./ascii": {
      "import": {
        "types": "./dist/ascii.d.ts",
        "default": "./dist/ascii.js"
      },
      "require": {
        "types": "./dist/ascii.d.cts",
        "default": "./dist/ascii.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "mocha",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "keywords": ["typescript", "library", "chessboard"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "chai": "^5.0.0",
    "mocha": "^10.2.0",
    "tsdown": "^0.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
